#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./common.sh
source "$script_dir/common.sh"

notify() {
  if command -v tt >/dev/null 2>&1; then
    tt notify "$1" || true
  fi
}

print_help() {
  echo "Usage: ./ralph-loop [options]"
  echo ""
  echo "Run repeated Codex passes against a local checklist file."
  echo ""
  echo "Options:"
  echo "  -c, --checklist <path>            Checklist file path (default: ./CHECKLIST.md)"
  echo "  -i, --instructions <path>        Instructions file path (default: ./INSTRUCTIONS.md)"
  echo "  -n, --iterations <count>           Number of iterations to run (default: 10)"
  echo "  -p, --progress <path>             Progress log path (default: ./PROGRESS.md)"
  echo "      --yolo                        Use --dangerously-bypass-approvals-and-sandbox"
  echo "  -h, --help                         Show this help"
}

iterations=10
invocation_dir="$(pwd)"
checklist_path=""
instructions_path=""
progress_path=""
yolo="false"
while [[ $# -gt 0 ]]; do
  case "$1" in
    -c|--checklist)
      if [[ $# -lt 2 ]]; then
        echo "Error: $1 requires a value" >&2
        exit 1
      fi
      checklist_path="$2"
      shift 2
      ;;
    -i|--instructions)
      if [[ $# -lt 2 ]]; then
        echo "Error: $1 requires a value" >&2
        exit 1
      fi
      instructions_path="$2"
      shift 2
      ;;
    -n|--iterations)
      if [[ $# -lt 2 ]]; then
        echo "Error: $1 requires a value" >&2
        exit 1
      fi
      iterations="$2"
      shift 2
      ;;
    -p|--progress)
      if [[ $# -lt 2 ]]; then
        echo "Error: $1 requires a value" >&2
        exit 1
      fi
      progress_path="$2"
      shift 2
      ;;
    --yolo)
      yolo="true"
      shift
      ;;
    -h|--help)
      print_help
      exit 0
      ;;
    --*)
      echo "Unknown option: $1" >&2
      echo "Use --help for usage information" >&2
      exit 1
      ;;
    *)
      echo "Unknown argument: $1" >&2
      echo "Use --checklist to provide a checklist file path" >&2
      echo "Use --help for usage information" >&2
      exit 1
      ;;
  esac
done

if ! [[ "$iterations" =~ ^[1-9][0-9]*$ ]]; then
  echo "Error: --iterations must be a positive integer, got: $iterations" >&2
  exit 1
fi

require_command "codex" "Codex CLI"

input_file="$(resolve_input_file "$checklist_path" "$script_dir/CHECKLIST.md" "$invocation_dir")"
instruction_file="$(resolve_input_file "$instructions_path" "$script_dir/INSTRUCTIONS.md" "$invocation_dir")"
progress_file="$(resolve_input_file "$progress_path" "$script_dir/PROGRESS.md" "$invocation_dir")"

require_file "$input_file" "Input file"
require_file "$instruction_file" "Prompt file"
require_file "$progress_file" "Progress file"

for ((i=1; i<=iterations; i++)); do
  echo "Iteration $i"
  echo "--------------------------------"
  result="$(run_codex_pass "$invocation_dir" "$input_file" "$progress_file" "$instruction_file" "$yolo")"

  echo "$result"

  if [[ "$result" == *"<promise>COMPLETE</promise>"* ]]; then
    echo "Checklist complete, exiting."
    notify "Checklist complete after $i iterations"
    exit 0
  fi
done

echo "Checklist not complete after $iterations iterations." >&2
notify "Checklist not complete after $iterations iterations"
exit 1
