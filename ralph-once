#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./common.sh
source "$script_dir/common.sh"

print_help() {
  echo "Usage: ./ralph-once [options]"
  echo ""
  echo "Run a single Codex pass against a local checklist file."
  echo ""
  echo "Options:"
  echo "  -c, --checklist <path>            Checklist file path (default: ./CHECKLIST.md)"
  echo "  -i, --instructions <path>        Instructions file path (default: ./INSTRUCTIONS.md)"
  echo "  -p, --progress <path>             Progress log path (default: ./PROGRESS.md)"
  echo "      --yolo                        Use --dangerously-bypass-approvals-and-sandbox"
  echo "  -h, --help                         Show this help"
}

invocation_dir="$(pwd)"
checklist_path=""
instructions_path=""
progress_path=""
yolo="false"
while [[ $# -gt 0 ]]; do
  case "$1" in
    -c|--checklist)
      if [[ $# -lt 2 ]]; then
        echo "Error: $1 requires a value" >&2
        exit 1
      fi
      checklist_path="$2"
      shift 2
      ;;
    -i|--instructions)
      if [[ $# -lt 2 ]]; then
        echo "Error: $1 requires a value" >&2
        exit 1
      fi
      instructions_path="$2"
      shift 2
      ;;
    -p|--progress)
      if [[ $# -lt 2 ]]; then
        echo "Error: $1 requires a value" >&2
        exit 1
      fi
      progress_path="$2"
      shift 2
      ;;
    --yolo)
      yolo="true"
      shift
      ;;
    -h|--help)
      print_help
      exit 0
      ;;
    --*)
      echo "Unknown option: $1" >&2
      echo "Use --help for usage information" >&2
      exit 1
      ;;
    *)
      echo "Unknown argument: $1" >&2
      echo "Use --checklist to provide a checklist file path" >&2
      echo "Use --help for usage information" >&2
      exit 1
      ;;
  esac
done

require_command "codex" "Codex CLI"

input_file="$(resolve_input_file "$checklist_path" "$script_dir/CHECKLIST.md" "$invocation_dir")"
instruction_file="$(resolve_input_file "$instructions_path" "$script_dir/INSTRUCTIONS.md" "$invocation_dir")"
progress_file="$(resolve_input_file "$progress_path" "$script_dir/PROGRESS.md" "$invocation_dir")"

require_file "$input_file" "Input file"
require_file "$instruction_file" "Prompt file"
require_file "$progress_file" "Progress file"
run_codex_pass "$invocation_dir" "$input_file" "$progress_file" "$instruction_file" "$yolo"
