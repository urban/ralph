#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./common.sh
source "$script_dir/common.sh"

print_help() {
  echo "Usage: ./ralph-once [input-file-path]"
  echo ""
  echo "Run a single Codex pass against a local checklist file."
  echo ""
  echo "Arguments:"
  echo "  [input-file-path]                 Checklist file path"
  echo "                                    Backward-compatible alias for --checklist"
  echo ""
  echo "Options:"
  echo "  -c, --checklist <path>            Checklist file path (default: ./CHECKLIST.md)"
  echo "  -n, --instructions <path>        Instructions file path (default: ./INSTRUCTIONS.md)"
  echo "  -p, --progress <path>             Progress log path (default: ./PROGRESS.md)"
  echo "      --yolo                        Use --dangerously-bypass-approvals-and-sandbox"
  echo "  -h, --help                         Show this help"
}

invocation_dir="$(pwd)"
checklist_path=""
instructions_path=""
progress_path=""
yolo="false"
positionals=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -c|--checklist)
      if [[ $# -lt 2 ]]; then
        echo "Error: $1 requires a value" >&2
        exit 1
      fi
      checklist_path="$2"
      shift 2
      ;;
    -n|--instructions)
      if [[ $# -lt 2 ]]; then
        echo "Error: $1 requires a value" >&2
        exit 1
      fi
      instructions_path="$2"
      shift 2
      ;;
    -p|--progress)
      if [[ $# -lt 2 ]]; then
        echo "Error: $1 requires a value" >&2
        exit 1
      fi
      progress_path="$2"
      shift 2
      ;;
    --yolo)
      yolo="true"
      shift
      ;;
    -h|--help)
      print_help
      exit 0
      ;;
    --*)
      echo "Unknown option: $1" >&2
      echo "Use --help for usage information" >&2
      exit 1
      ;;
    *)
      positionals+=("$1")
      shift
      ;;
  esac
done

if [[ "${#positionals[@]}" -gt 1 ]]; then
  echo "Error: At most one input file path is allowed" >&2
  echo "Usage: ./ralph-once [input-file-path]" >&2
  exit 1
fi

if [[ -n "$checklist_path" && "${#positionals[@]}" -gt 0 ]]; then
  echo "Error: Use either [input-file-path] or --checklist, not both" >&2
  exit 1
fi

require_command "codex" "Codex CLI"

if [[ -z "$checklist_path" && "${#positionals[@]}" -gt 0 ]]; then
  checklist_path="${positionals[0]}"
fi

input_file="$(resolve_input_file "$checklist_path" "$script_dir/CHECKLIST.md" "$invocation_dir")"
instruction_file="$(resolve_input_file "$instructions_path" "$script_dir/INSTRUCTIONS.md" "$invocation_dir")"
progress_file="$(resolve_input_file "$progress_path" "$script_dir/PROGRESS.md" "$invocation_dir")"

require_file "$input_file" "Input file"
require_file "$instruction_file" "Prompt file"
require_file "$progress_file" "Progress file"
run_codex_pass "$invocation_dir" "$input_file" "$progress_file" "$instruction_file" "$yolo"
