{
  "name": "ralph-effect",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "ralph": "./src/cli.ts"
  },
  "files": [
    "src/**/*.ts",
    "src/templates/*.md",
    "ralph",
    "ralph-once",
    "ralph-loop"
  ],
  "type": "module",
  "scripts": {
    "check": "bun run lint && bun run typecheck && bun run test",
    "cli": "bun src/cli.ts",
    "lint": "oxfmt && oxlint --fix",
    "prepare": "effect-language-service patch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.49",
    "effect": "4.0.0-beta.49"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@effect/language-service": "0.85.1",
    "@types/bun": "latest",
    "husky": "9.1.7",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "typescript": "6.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxfmt",
      "oxlint --fix"
    ],
    "*.{css,html,json,jsonc,md,mdx,yml,yaml}": [
      "oxfmt"
    ]
  },
  "engines": {
    "bun": ">= 1.3.5",
    "node": ">= 24.12.0"
  },
  "packageManager": "bun@1.3.5"
}
